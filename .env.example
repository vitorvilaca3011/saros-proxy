# OpenCode-Go Multi-Account Proxy — Environment Configuration
# Copy this file to .env and customize for your setup.

# Proxy server
PROXY_PORT=3000
PROXY_HOST=127.0.0.1
UPSTREAM_BASE_URL=https://opencode.ai

# API keys (comma-separated label:key pairs)
OPENCODE_GO_KEYS="account1:sk-xxx,account2:sk-yyy"

# Circuit breaker
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_COOLDOWN_MS=60000

# Request timeout (ms)
REQUEST_TIMEOUT_MS=30000

# Logging
LOG_LEVEL=info
NODE_ENV=production
