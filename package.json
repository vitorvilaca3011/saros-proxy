{
  "name": "opencode-go-proxy",
  "version": "0.1.0",
  "description": "Multi-account proxy for OpenCode-Go API with failover and streaming",
  "type": "module",
  "bin": {
    "opencode-go-proxy": "./dist/index.js",
    "opencode-go-proxy-setup": "./dist/cli/setup.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "setup": "tsx src/cli/setup.ts",
    "prototype": "tsx prototype/prototype.ts",
    "proto:usage": "tsx prototype/usage-switching.ts",
    "proto:probe": "tsx prototype/api-probe.ts",
    "proto:scrape": "tsx prototype/dashboard-scraper.ts",
    "proto:setup": "tsx prototype/setup-wizard.ts",
    "proto:autostart": "tsx prototype/auto-start.ts",
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest",
    "docker:build": "docker compose build proxy",
    "docker:run": "docker compose up proxy",
    "docker:test": "docker compose run --rm test"
  },
  "keywords": [
    "opencode",
    "proxy",
    "multi-account",
    "failover",
    "load-balancer",
    "api-gateway",
    "circuit-breaker"
  ],
  "author": "OpenCode-Go Proxy Contributors",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opencode-go/proxy.git"
  },
  "bugs": {
    "url": "https://github.com/opencode-go/proxy/issues"
  },
  "homepage": "https://github.com/opencode-go/proxy#readme",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.8",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "@hono/node-server": "^2.0.4",
    "chalk": "^5.6.2",
    "hono": "^4.12.23",
    "hono-rate-limiter": "^0.5.3",
    "pino": "^10.3.1",
    "yaml": "^2.9.0"
  }
}
